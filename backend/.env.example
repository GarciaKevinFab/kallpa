# =============================================
# Kallpa Backend - Variables de Entorno
# =============================================
# Copiar a .env y completar con valores reales.
# NUNCA commitear el archivo .env al repositorio.

# --- n8n Webhook URLs ---
# URL del webhook para agendamiento de citas
N8N_WEBHOOK_AGENDAMIENTO=https://tu-n8n-instance.com/webhook/agendamiento

# URL del webhook para consulta de disponibilidad
N8N_WEBHOOK_DISPONIBILIDAD=https://tu-n8n-instance.com/webhook/disponibilidad

# URL del webhook para triaje y alertas
N8N_WEBHOOK_TRIAJE=https://tu-n8n-instance.com/webhook/triaje-alertas

# URL del webhook para confirmacion de citas
N8N_WEBHOOK_CONFIRMACION=https://tu-n8n-instance.com/webhook/confirmacion

# --- n8n Autenticacion (opcional) ---
# Token Bearer para autenticar requests a n8n
# N8N_AUTH_TOKEN=tu-token-secreto

# --- Google Calendar (opcional, para integracion directa) ---
# Ruta al archivo JSON de credenciales de servicio de Google
# GOOGLE_CALENDAR_CREDENTIALS=/path/to/service-account.json

# --- Servidor ---
# Puerto del servidor FastAPI
PORT=8000

# Entorno: development | staging | production
ENVIRONMENT=development
